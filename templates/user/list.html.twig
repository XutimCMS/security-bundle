{% extends '@XutimCore/admin/settings/settings_layout.html.twig' %}

{% block title %}{{ 'users'|trans({}, 'admin')|capitalize }}{% endblock %}

{% block pageMenu %}
    <twig:Xutim:Admin:Button
        tag="a"
        variant="nav"
        data-turbo-frame="modal"
        href="{{ admin_path('admin_user_new') }}"
    >
        <twig:Xutim:Admin:Icon name="users" class="me-1" />
        {{ 'add a new user'|trans({}, 'admin')|capitalize }}
    </twig:Xutim:Admin:Button>
{% endblock %}

{% block breadcrumbHeader %}
    <twig:Xutim:Admin:Breadcrumbs>
        <li class="breadcrumb-item">
            <a href="{{ admin_path('admin_settings_site') }}">
                {{ 'settings'|trans({}, 'admin')|capitalize }}
            </a>
        </li>
        <li class="breadcrumb-item">Users</li>
    </twig:Xutim:Admin:Breadcrumbs>
{% endblock %}

{% block settingsBody %}
    {% set roleOptions = [
        {label: 'User'|trans({}, 'admin'), value: 'ROLE_USER'},
        {label: 'Translator'|trans({}, 'admin'), value: 'ROLE_TRANSLATOR'},
        {label: 'Editor'|trans({}, 'admin'), value: 'ROLE_EDITOR'},
        {label: 'Admin'|trans({}, 'admin'), value: 'ROLE_ADMIN'},
        {label: 'Developer'|trans({}, 'admin'), value: 'ROLE_DEVELOPER'},
    ] %}

    {% set localeOptions = [] %}
    {% for locale in site_context.allLocales %}
        {% set localeOptions = localeOptions|merge([{label: locale|upper, value: locale}]) %}
    {% endfor %}

    <div class="row">
        <div class="col-md-12">
            <h2 class="mb-2 py-2">
                {{ 'users'|trans({}, 'admin')|capitalize }}
            </h2>
            {%
                component 'Xutim:Admin:DataTable' with {
                    frameId: 'users-list',
                    pager: users,
                    filter: filter,
                    tableBodyId: 'user-list-body',
                    showChips: true,
                    columns: [
                        {
                            key: '_avatar',
                            label: '',
                            sortable: false,
                        },
                        {
                            key: 'name',
                            label: 'name'|trans({}, 'admin')|capitalize,
                            sortable: true,
                            order: 'name',
                        },
                        {
                            key: 'email',
                            label: 'email'|trans({}, 'admin')|capitalize,
                            sortable: true,
                            order: 'email',
                        },
                        {
                            key: 'role',
                            label: 'roles'|trans({}, 'admin')|capitalize,
                            sortable: true,
                            order: 'roles',
                            filter: {
                                type: 'select',
                                options: roleOptions,
                                placeholder: 'Any'|trans({}, 'admin'),
                                minWidth: '180px',
                            },
                            chip: true,
                        },
                        {
                            key: 'locale',
                            label: 'locales'|trans({}, 'admin')|capitalize,
                            sortable: false,
                            filter: {
                                type: 'select',
                                options: localeOptions,
                                placeholder: 'Any'|trans({}, 'admin'),
                                minWidth: '180px',
                            },
                            chip: true,
                        },
                        {
                            key: '_actions',
                            label: '',
                            sortable: false,
                        },
                    ],
                }
            %}
            {% block body %}
                {% for user in users %}
                    {{ include('@XutimSecurity/user/_user_row.html.twig') }}
                {% endfor %}
            {% endblock %}
            {% endcomponent %}
        </div>
    </div>
{% endblock %}
